# Perch build-time configuration — read by Vite and BAKED INTO the renderer
# bundle at `npm run dist:*`. Copy to `.env` and fill in before a real release.
# (Dev has sane localhost defaults, so this file is only needed for distribution.)

# WebSocket URL of your hosted signaling server. Use wss:// in production so it
# works from a packaged app (an https origin cannot open an insecure ws://).
# Unset default is ws://localhost:8787 (local dev only).
VITE_SIGNAL_URL=wss://signal.example.com

# JSON array of RTCIceServer. For peers on DIFFERENT networks you MUST include a
# TURN relay — STUN alone fails behind most home/corporate NATs. Unset default is
# Google STUN only (fine on a shared LAN, not across the internet).
VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"USER","credential":"PASS"}]
