# Perch build-time configuration — read by Vite and BAKED INTO the renderer
# bundle at `npm run dist:*` (and by `npm run dev`). Copy to `.env` and fill in
# before a real release. `.env` is gitignored; this template is committed.
# (Dev has sane localhost/LAN defaults, so this file is only needed to point a
# build at a hosted signaling server — i.e. pairing across the internet.)

# WebSocket URL of your hosted signaling server. Use wss:// in production so it
# works from a packaged app (a secure origin cannot open an insecure ws://).
# No trailing slash, no path: the standalone server accepts the upgrade at root.
# When set, the Connect screen drops the IP field — pairing is by code alone.
# Unset default is ws://localhost:8787 (local dev / embedded LAN rendezvous).
VITE_SIGNAL_URL=wss://signal.example.com

# ICE servers (JSON array of RTCIceServer). For peers on DIFFERENT networks you
# MUST include a TURN relay — STUN alone fails behind symmetric NATs (common on
# home routers / mobile). Unset default is Google STUN only (fine on a shared
# LAN and many home networks, not guaranteed across the internet).
VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"USER","credential":"PASS"}]
